# Launch switch (server-only, read at request time).
#   unset / false -> coming-soon countdown page (default)
#   true          -> the real portfolio site
#
# Local: set to "true" while building the real site so you can see it.
# Production: leave unset/false until launch. Flip to false + redeploy to roll
# back to the coming-soon page in an emergency.
LAUNCHED=false
